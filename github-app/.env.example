# Probot/GitHub App configuration
# Rename to .env and fill in values

# Standard Probot variables
APP_ID=
# PRIVATE_KEY expects the full PEM content. For multi-line content, either:
#  - paste with literal newlines, or
#  - provide a path and load it yourself; Probot accepts inline PEM.
PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
WEBHOOK_SECRET=

# Where to dispatch the workflow that processes an issue
# Must be the full repo name (owner/repo) of this infrastructure repository
INFRA_REPO=
# Branch or tag to dispatch against
INFRA_REF=main
# Path to the workflow in the infra repo
WORKFLOW_FILE=.github/workflows/process-issue.yml

# Dataset repository (owner/repo)
DATASET_REPO=

# Optional controls
GENERATOR=java
AUTO_MERGE=false
# When true, the app logs intended workflow dispatches without calling GitHub (for local testing)
DRY_RUN=false


# Local validation endpoint requirements
# GH_TOKEN is used by local /validate endpoint and scripts to call GitHub API via gh CLI
GH_TOKEN=
# Optional: path to Python 3 binary used to run scripts
PYTHON_BIN=python3
